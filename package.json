{
  "name": "zdp-client-sdks",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "description": "ZDP client SDK contract skeleton.",
  "scripts": {
    "check": "tsc --noEmit && bun test && bun run contracts:check && bun run generation:plan -- --check",
    "check:tsgo": "tsgo --noEmit",
    "test": "bun test",
    "contracts:check": "bun scripts/check-client-sdk-contracts.ts",
    "generation:plan": "bun scripts/plan-sdk-generation.ts --api-contracts-root ../zdp-api-contracts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260603.1",
    "typescript": "^6.0.3"
  }
}
